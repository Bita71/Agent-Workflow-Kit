{
  "//": "Copy to .claude/settings.local.json and adapt to your repo. Keep CHECK_COMMAND in .agent-workflow-kit/config.conf; add only the exact low-risk shell permissions this project needs.",
  "permissions": {
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)"
    ]
  }
}
